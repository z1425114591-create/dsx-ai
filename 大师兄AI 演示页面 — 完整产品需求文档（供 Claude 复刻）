## 十二、状态管理（主组件 state）

```typescript
const [messages, setMessages] = useState<Message[]>([]);
const [isTyping, setIsTyping] = useState(false);
const [inputVal, setInputVal] = useState("");
const [phase, setPhase] = useState<PhaseType>("welcome");
const [selectedCat, setSelectedCat] = useState<string>("car");
const selectedCatRef = useRef<string>("car");       // 用于异步回调中读取最新值
const [selectedDirection, setSelectedDirection] = useState<string | null>(null);
const selectedDirectionRef = useRef<string | null>(null);
const [selectedTags, setSelectedTags] = useState<string[]>([]);
const [activeCardMsgId, setActiveCardMsgId] = useState<string | null>(null);
const [showCatDropdown, setShowCatDropdown] = useState(false);
const bottomRef = useRef<HTMLDivElement>(null);     // 自动滚动到底部
const catDropdownRef = useRef<HTMLDivElement>(null); // 点击外部关闭下拉
```

**注意**：`selectedCatRef` 和 `selectedDirectionRef` 是 `useRef` 镜像，用于在 `setTimeout` 回调中读取最新的 state 值，避免闭包陈旧问题。

